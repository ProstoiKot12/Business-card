# Telegram
BOT_TOKEN=0000000000:replace-me
ADMIN_IDS=123456789          # comma-separated Telegram user IDs
OWNER_ID=987654321           # Telegram user ID for startup/shutdown notifications

# Owner profile (shown in Contacts section)
OWNER_NAME=Ваше имя
OWNER_TELEGRAM_URL=https://t.me/username
OWNER_GITHUB_URL=https://github.com/username
OWNER_PHONE=+79991234567
OWNER_MAX_URL=https://max.ru/username

# Infrastructure
DATABASE_URL=postgresql+asyncpg://bot:bot@127.0.0.1:5432/business_card_bot
REDIS_URL=redis://127.0.0.1:6379/0
LOG_LEVEL=INFO

# Web App
WEBAPP_URL=https://your-domain.example/webapp
MAIN_PHOTO_FILE_ID=          # optional: Telegram file_id for main menu photo
